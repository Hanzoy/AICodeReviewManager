# 对外访问管理界面的端口和地址。
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=5173
MANAGER_PUBLIC_URL=http://localhost:5173

# 默认构建到本机；发布到镜像仓库后可改成仓库中的镜像名。
CODE_REVIEW_IMAGE=code-review-helper:local
CODE_REVIEW_WEB_IMAGE=code-review-helper-web:local
CODE_REVIEW_NETWORK=code-review

# Docker 与直接运行 Node 共用的数据根目录。
# Windows 也可以写成 E:/Projects/CodeReviewHelper/data。
CODE_REVIEW_DATA_DIR=./data

# 固定 Review 执行器版本，确保不同部署得到一致行为。
CLAUDE_CODE_VERSION=2.1.211
