# 从管理界面“注册节点”弹窗复制。
GROUP_ID=00000000-0000-0000-0000-000000000000
ENROLL_TOKEN=enroll_replace_me
GROUP_NAME=示例项目组

# 同一台 Docker 主机使用下面的内部地址；跨主机部署时改为管理端可访问地址。
MANAGER_INTERNAL_URL=http://manager:7000
# 同机部署无需修改；跨主机部署时填写管理端可回连的项目组节点 URL。
# GROUP_PUBLIC_URL=http://group-node.example.com:7100
CODE_REVIEW_IMAGE=code-review-helper:local
CODE_REVIEW_NETWORK=code-review
# 必须与管理端指向同一个数据根目录。
# Windows 也可以写成 E:/Projects/CodeReviewHelper/data。
CODE_REVIEW_DATA_DIR=./data
CLAUDE_CODE_VERSION=2.1.211
